# Supabase
# Hol dir diese Werte aus: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# Google Gemini
# API Key aus: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Meta / Instagram App
# App erstellen unter: https://developers.facebook.com
# Produkt "Instagram Basic Display" hinzufügen
META_APP_ID=123456789
META_APP_SECRET=abc123def456...
META_REDIRECT_URI=http://localhost:3000/api/auth/callback

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
